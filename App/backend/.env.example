SECRET_KEY=your-secret-key-here

# AWS — necesario para subir comprobantes a S3
# Bucket real desplegado por Terraform (storage module):
#   ${project_name}-${environment}-storage  →  proyecto-trimestre2-dev-storage
AWS_REGION=us-east-1
S3_BUCKET=proyecto-trimestre2-dev-storage

# SQS — URLs inyectadas por Terraform en Lambda como env vars.
# En local, dejar vacío: las llamadas SQS se omiten silenciosamente.
SQS_NOTIFICATIONS_QUEUE_URL=
SQS_EXPIRY_QUEUE_URL=
